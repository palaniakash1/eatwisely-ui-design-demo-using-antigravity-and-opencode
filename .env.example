# ===================================================================
# Development Environment Configuration
# ===================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control (already in .gitignore)
# ===================================================================

# Server
PORT=3001
NODE_ENV=development

# Application
APP_NAME=mern-restaurant
APP_VERSION=1.0.0

# Database (Required)
DATABASE_URL=mongodb://localhost:27017/eatwisely

# JWT (Required - Use a secure secret in production)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRE=1h
JWT_ISSUER=mern-restaurant-api
JWT_AUDIENCE=mern-restaurant-client
JWT_ROTATION_ENABLED=true

# Security
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3001

# Redis (Optional)
# REDIS_URL=redis://localhost:6379

# External Services (Optional)
# GOOGLE_MAPS_API_KEY=
# EMAIL_SERVICE_URL=

# Monitoring
OTEL_ENABLED=false

# Performance
CACHE_TTL=300
REDIS_CONNECT_TIMEOUT=2000

# Token Refresh
REFRESH_TOKEN_TTL_DAYS=14

# Metrics (Optional)
# METRICS_TOKEN=your-metrics-token

# Health Check Options
HEALTH_CHECK_INCLUDE_MONGO=false
HEALTH_CHECK_INCLUDE_DEPS=false
